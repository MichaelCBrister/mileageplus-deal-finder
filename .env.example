# MileagePlus Deal Finder — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Required: Anthropic API key for Claude API (T&C parsing + search query interpretation)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: MileagePlus portal credentials (for live scraping after manual 2FA login)
MILEAGEPLUS_USERNAME=your-mileageplus-username
MILEAGEPLUS_PASSWORD=your-mileageplus-password

# Optional: Override defaults
JULIA_ENGINE_PORT=5001
BRIDGE_PORT=4000
NODE_ENV=production
FRESHNESS_HOURS=24
